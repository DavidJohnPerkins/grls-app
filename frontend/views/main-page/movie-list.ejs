<%- include('../includes/head.ejs') %>
<link rel="stylesheet" href="/css/main.css">
<link rel="stylesheet" href="/css/model.css">
</head>

	<body>
		<%- include('../includes/navigation.ejs') %>

		<main>
			<% if (movies.length > 0) { %>
				<div class="grid">
					<% for (let movie of movies) { %>
						<article class="card model-item">
							<header class="card__header">
								<h1 class="model__name">
									<%= movie.title %>
								</h1>
							</header>
							<div class="model__image">
								<img src="movie-image/<%= movie.title %>_1.png" alt="<%= movie.title %>">
								<img src="movie-image/<%= movie.title %>_2.png" alt="<%= movie.title %>">
							</div>
							<div class="model__image">
								<img src="movie-image/<%= movie.title %>_3.png" alt="<%= movie.title %>">
								<img src="movie-image/<%= movie.title %>_4.png" alt="<%= movie.title %>">
							</div>
							<div class="card__content">
								<h2 class="model__hq">
									<%= movie.rating %>
								</h2>
								<p class="model__nationality">
									<%= movie.comment %>
								</p>
								<p class="model__flags">
									<%= movie.flags %>
								</p>
							</div>
							<div class="card__actions">
								<a href="/movie/<%= movie.title %>" class="btn">Play</a>
							</div>
						</article>
					<% } %>
				</div>
			<% } else { %>
				<h1>No Movies Found</h1>
			<% } %>
		</main>
		<%- include('../includes/end.ejs') %>